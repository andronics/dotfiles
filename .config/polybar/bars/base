[bar/base]
monitor = ${env:MONITOR:LVDS1}
monitor-fallback = DP-2
monitor-strict = false 
monitor-exact = true
override-redirect = false
wm-restack = bspwm
enable-ipc = true
fixed-center = true
;separator = |

background = ${colors.background}
foreground = ${colors.foreground}

offset-x = 2.5%
offset-y = 3%

radius = 13

line-size = 1
;padding = 10

;cursor-click = pointer
;cursor-scroll = default

font-0 = JetBrainsMonoMedium:pixelsize=8;
;font-1 = HackNerdFontMono:pixelsize=12;
font-1 = NotoSansMono Nerd Font:pixelsize=10;
font-2 = NotoColorEmoji:fontformat=truetype:scale=10:antialias=false;
font-3 = FontAwesome:fontformat=opentype:pixelsize:10;
font-4 = WeatherIcons:size=8;
font-6 = FontAwesomeBrands:fontformat=opentype:pixelsize:10;

module-margin-left = 0